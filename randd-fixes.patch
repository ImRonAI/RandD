-      // drop any previous baked-in state so re-exports stay clean
-      source = source.replace(/<script>window\.__QC_STATE__[\s\S]*?<\/script>\n?/, '');
+      // Drop any previous baked-in state so re-exports stay clean. The "= \{"
+      // anchor matches only a real boot script (JSON starts with {), never the
+      // quoted literal in this code — without it the regex ate everything from
+      // here to the file's final closing script tag, truncating the export.
+      source = source.replace(/<script>window\.__QC_STATE__ = \{[\s\S]*?<\/script>\n?/, '');
       const boot = '<script>window.__QC_STATE__ = ' +
         JSON.stringify(state).replace(/<\/script/gi, '<\\/script') + ';<\/script>';
-      return source.replace('<script>', boot + '\n<script>');
+      // Replacer function so "$" sequences in notes/media can't corrupt the doc.
+      return source.replace('<script>', function(){ return boot + '\n<script>'; });
     }
   };
 
