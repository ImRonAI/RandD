{
  "name": "randd",
  "private": true,
  "scripts": {
    "predev": "lsof -ti:8000,5173 | xargs -r kill; exit 0",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:frontend": "wait-on -t 30000 http-get://localhost:8000/api/models && npm --prefix frontend run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.2"
  }
}
