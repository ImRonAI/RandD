# === STR QC Platform — environment template ===
# Copy to .env and fill in. NEVER commit real values.
# (If a real key ever lands in this file, rotate it immediately — git history keeps it forever.)

# --- Core ---
STRQC_DB_PATH=./str_qc.sqlite
# 32-byte base64 key for envelope encryption of door codes / wifi passwords.
# Generate: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
STRQC_MASTER_KEY=
# Local photo storage root (inspection/report images)
STRQC_PHOTO_DIR=./photostore

# --- BIDI voice model selection ---
# Which realtime provider the agent uses by default: gemini | openai | nova
# The web voice console can switch providers per-session via the model picker.
STRQC_BIDI_PROVIDER=gemini

# --- Gemini Live (default provider) ---
GOOGLE_API_KEY=
STRQC_GEMINI_MODEL_ID=gemini-3.1-flash-live-preview

# --- OpenAI Realtime (provider: openai) ---
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_MODEL=gpt-realtime-2

# --- Amazon Nova Sonic 2 via Bedrock (provider: nova) ---
# Uses the standard AWS credential chain (env vars, ~/.aws, IAM role, SSO).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
STRQC_NOVA_MODEL_ID=amazon.nova-2-sonic-v1:0

# --- Slack delivery (Addendum 1) ---
# Slack app with chat:write + files:write scopes.
# Leave SLACK_BOT_TOKEN empty to use the dry-run delivery adapter (dev/tests).
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL_ID=

# --- Escapia HSAPI (Addendum 2) ---
ESCAPIA_BASE_URL=https://hsapi.escapia.com/dragomanadapter
ESCAPIA_CLIENT_ID=
ESCAPIA_CLIENT_SECRET=
ESCAPIA_PMC_ID=
ESCAPIA_API_VERSION=1
ESCAPIA_END_SYSTEM=EscapiaVRS

# --- Google tools (strands-google: Sheets/Maps/Gmail) ---
# Option A (primary): a GCP service-account key file.
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: user OAuth — download the OAuth client JSON from Google Cloud Console
# as gmail_credentials.json, run `python gmail_auth.py` (writes gmail_token.json),
# then point GOOGLE_OAUTH_CREDENTIALS at the token.
GOOGLE_OAUTH_CLIENT=gmail_credentials.json
GOOGLE_OAUTH_TOKEN=gmail_token.json
GOOGLE_OAUTH_CREDENTIALS=
# Optional: space/comma-separated scope override (defaults to strands_google DEFAULT_SCOPES)
# GOOGLE_OAUTH_SCOPES=

# --- API service ---
STRQC_API_HOST=0.0.0.0
STRQC_API_PORT=8000
# Secret for signing session tokens (dev only; use a secret manager in prod)
STRQC_SESSION_SECRET=

# --- Web app (apps/web/.env.local) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/voice
