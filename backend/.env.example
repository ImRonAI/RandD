# Copy to backend/.env and fill in real values. NEVER commit .env (it is gitignored).

# Gemini Live
GOOGLE_API_KEY=your_google_api_key
#GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
#GEMINI_THINKING_LEVEL=HIGH

# AWS credentials for the Bedrock Knowledge Base memory store
# (standard AWS credential chain — same as the Bedrock model provider).
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-west-2

# Bedrock Knowledge Base memory (Strands BedrockKnowledgeBaseStore)
BEDROCK_KB_ID=LAJ1DYSVHG
# Provided => skips the GetKnowledgeBase detection call; unset to auto-detect.
BEDROCK_KB_TYPE=MANAGED
# With only the KB ID the store is read-only. To enable add_memory writes,
# point at the S3 data source (knowledge-base-quick-start-22vlm-data-source):
#BEDROCK_KB_DATA_SOURCE_ID=your_data_source_id
#BEDROCK_KB_DATA_SOURCE_TYPE=S3
#BEDROCK_KB_S3_BUCKET=your_kb_data_source_bucket
#BEDROCK_KB_S3_PREFIX=memories/
# Optional namespace isolating documents within the KB:
#BEDROCK_KB_SCOPE=randd-live

# Inspection-report archive folder inside the KB bucket (app/kb_archive.py).
# Summaries land under <BEDROCK_KB_S3_PREFIX><KB_REPORTS_FOLDER>/ (ingested by
# the KB => searchable memory); full HTML artifacts land under
# <KB_REPORTS_FOLDER>/artifacts/ (outside the data-source prefix, not indexed).
# Bootstrap the folders once with: python -m app.kb_archive --init
#KB_REPORTS_FOLDER=inspection-reports
# Vantage production session and tenant bootstrap
VANTAGE_SESSION_SECRET=
VANTAGE_ALLOWED_EMAILS=
VANTAGE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VANTAGE_ENV=development
VANTAGE_DB_PATH=backend/workspace/vantage-v1.sqlite

# Vantage original media evidence store (DAH-131)
# Bucket must be created with S3 Object Lock enabled, versioning enabled, and
# blocked public access. Use a KMS key ARN/ID that HeadObject will report back
# in SSEKMSKeyId; aliases are accepted by S3 writes but may not match reads.
#VANTAGE_S3_BUCKET=vantage-originals-285527663773-us-east-1
#VANTAGE_S3_REGION=us-east-1
#VANTAGE_S3_EXPECTED_BUCKET_OWNER=285527663773
#VANTAGE_S3_KMS_KEY_ID=arn:aws:kms:us-east-1:285527663773:key/...
#VANTAGE_S3_RETENTION_DAYS=2557
#VANTAGE_S3_SIGNED_READ_SECONDS=300

# Google Calendar + Maps Routes + Places
# Calendar access tokens are a local integration bridge. Production should
# supply per-user encrypted OAuth refresh tokens through the connection store.
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=
GOOGLE_MAPS_API_KEY=
